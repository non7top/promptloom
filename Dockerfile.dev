FROM node:22-bookworm

# Electron (Chromium) runtime dependencies + Xvfb for headless GUI runs.
RUN apt-get update && apt-get install -y --no-install-recommends \
    xvfb \
    xauth \
    libnss3 \
    libatk1.0-0 \
    libatk-bridge2.0-0 \
    libgtk-3-0 \
    libgbm1 \
    libasound2 \
    libxss1 \
    libxtst6 \
    libx11-xcb1 \
    libdrm2 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
