{
  "name": "promptloom",
  "productName": "PromptLoom",
  "version": "2.0.1",
  "description": "A companion app for keeping track of prompt/seed combinations while working on sprites for visual novels, using perchance.org's AI text-to-image generator. Not intended to bypass any restrictions of the platform or otherwise abuse it.",
  "main": "out/main/index.js",
  "private": true,
  "scripts": {
    "start": "electron-vite dev",
    "build": "electron-vite build",
    "package": "electron-vite build && electron-builder --dir",
    "make": "electron-vite build && electron-builder",
    "publish": "electron-vite build && electron-builder --publish always",
    "lint": "eslint --ext .ts,.tsx ."
  },
  "keywords": [],
  "author": {
    "name": "Vladimir Berezhnoy",
    "email": "non7top@gmail.com"
  },
  "license": "MIT",
  "devDependencies": {
    "@electron/fuses": "^2.1.3",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.65.0",
    "@typescript-eslint/parser": "^8.65.0",
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "typescript": "^5.3.3",
    "vite": "^7.3.6"
  },
  "dependencies": {
    "electron-context-menu": "^4.1.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
