{
  "name": "promptloom",
  "productName": "PromptLoom",
  "version": "4.0.1",
  "description": "A companion app for keeping track of prompt/seed combinations while working on sprites for visual novels, using perchance.org's AI text-to-image generator. Not intended to bypass any restrictions of the platform or otherwise abuse it.",
  "main": "out/main/index.js",
  "private": true,
  "scripts": {
    "start": "electron-vite dev",
    "build": "electron-vite build",
    "package": "electron-vite build && electron-builder --dir --publish never",
    "make": "electron-vite build && electron-builder --publish never",
    "publish": "electron-vite build && electron-builder --publish always",
    "lint": "biome lint ."
  },
  "keywords": [],
  "author": {
    "name": "Vladimir Berezhnoy",
    "email": "non7top@gmail.com"
  },
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@electron/fuses": "^2.1.3",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.4",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^6.0.0-beta.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.5"
  },
  "dependencies": {
    "electron-context-menu": "^4.1.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
